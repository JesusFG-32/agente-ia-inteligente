# ============================================================
# AGENTE IA INTELIGENTE - VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Google Gemini AI ---
GEMINI_API_KEY=tu_api_key_aqui

# --- MongoDB (Historial de Chats, Patrones, Anomalías) ---
MONGODB_URI=mongodb://localhost:27017/agente_ia

# --- PostgreSQL (Base de datos del Agente: Eventos) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agente_ia
DB_USER=postgres
DB_PASSWORD=tu_password_postgres

# --- Logging ---
AGENT_LOG_LEVEL=INFO

# --- VPS / SSH (para monitorear Nginx y MariaDB remotamente) ---
VPS_HOST=192.168.1.100
VPS_USER=ubuntu
VPS_KEY_PATH=keys/id_rsa
VPS_PORT=22

# --- MariaDB (Sistema a monitorear) ---
MARIADB_HOST=192.168.1.100
MARIADB_PORT=3306
MARIADB_USER=monitor_user
MARIADB_PASSWORD=tu_password_mariadb

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SECRET_KEY=cambia_esto_por_una_clave_secreta_segura
